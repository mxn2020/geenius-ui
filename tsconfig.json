{
    "compilerOptions": {
        "strict": true,
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "jsx": "react-jsx",
        "outDir": "dist",
        "rootDir": "."
    },
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.*",
        "**/*.spec.*"
    ]
}