{
    "name": "@geenius-ui/react",
    "version": "0.1.4",
    "private": false,
    "type": "module",
    "description": "React UI components — by Geenius",
    "author": "Mehdi Nabhani <mehdi@geenius.app>",
    "repository": {
        "type": "git",
        "url": "https://github.com/mxn2020/geenius-ui.git",
        "directory": "packages/react"
    },
    "keywords": [
        "ui",
        "components",
        "react",
        "design-system",
        "geenius",
        "tailwind"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "dev": "tsc --noEmit --watch",
        "build": "tsup",
        "clean": "rm -rf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "test": "vitest run",
        "type-check": "tsc --noEmit",
        "prepublishOnly": "pnpm clean && pnpm build"
    },
    "dependencies": {
        "@geenius-ui/shared": "workspace:*",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.5.0",
        "@tanstack/match-sorter-utils": "^8.19.4",
        "@tanstack/react-router": "^1.163.3",
        "@tanstack/react-table": "^8.21.3",
        "lucide-react": "^0.576.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tsup": "^8.4.0",
        "typescript": "^5.7.0"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    }
}