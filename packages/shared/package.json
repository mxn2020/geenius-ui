{
    "name": "@geenius-ui/shared",
    "version": "0.1.3",
    "private": false,
    "type": "module",
    "description": "Shared types and constants for @geenius-ui",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "type-check": "tsc --noEmit",
        "prepublishOnly": "pnpm clean && pnpm build"
    },
    "devDependencies": {
        "tsup": "^8.4.0",
        "typescript": "^5.7.0"
    }
}