{
    "name": "@geenius-ui/shared",
    "version": "0.1.5",
    "private": false,
    "type": "module",
    "description": "Shared types and constants for @geenius-ui",
    "author": "Mehdi Nabhani <mehdi@geenius.app>",
    "repository": {
        "type": "git",
        "url": "https://github.com/mxn2020/geenius-ui.git",
        "directory": "packages/shared"
    },
    "keywords": [
        "ui",
        "shared",
        "types",
        "constants",
        "geenius"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "dev": "tsc --noEmit --watch",
        "build": "tsup",
        "clean": "rm -rf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "test": "vitest run",
        "type-check": "tsc --noEmit",
        "prepublishOnly": "pnpm clean && pnpm build"
    },
    "devDependencies": {
        "tsup": "^8.4.0",
        "typescript": "^5.7.0"
    }
}
