{
    "name": "@geenius-ui/solid",
    "version": "0.1.5",
    "private": false,
    "type": "module",
    "description": "Solid UI components — by Geenius",
    "author": "Mehdi Nabhani <mehdi@geenius.app>",
    "repository": {
        "type": "git",
        "url": "https://github.com/mxn2020/geenius-ui.git",
        "directory": "packages/solid"
    },
    "keywords": [
        "ui",
        "components",
        "solid",
        "solidjs",
        "design-system",
        "geenius",
        "tailwind"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "dev": "tsc --noEmit --watch",
        "build": "tsc",
        "clean": "rm -rf dist",
        "lint": "eslint src --ext .ts,.tsx",
        "test": "vitest run",
        "type-check": "tsc --noEmit",
        "prepublishOnly": "pnpm clean && pnpm build"
    },
    "dependencies": {
        "@geenius-ui/shared": "workspace:*",
        "@tanstack/match-sorter-utils": "^8.11.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "lucide-solid": "^0.576.0",
        "tailwind-merge": "^2.6.0"
    },
    "devDependencies": {
        "solid-js": "^1.9.10",
        "typescript": "^5.7.0"
    },
    "peerDependencies": {
        "solid-js": "^1.9.0",
        "@tanstack/solid-table": "^8.20.0",
        "@tanstack/solid-router": "^1.0.0"
    },
    "peerDependenciesMeta": {
        "@tanstack/solid-table": {
            "optional": true
        },
        "@tanstack/solid-router": {
            "optional": true
        }
    }
}
