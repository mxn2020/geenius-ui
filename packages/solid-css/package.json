{
    "name": "@geenius-ui/solid-css",
    "version": "0.1.2",
    "private": false,
    "type": "module",
    "description": "Solid UI components with vanilla CSS — by Geenius",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./styles": "./src/styles/geenius-ui.css"
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "type-check": "tsc --noEmit",
        "prepublishOnly": "pnpm clean && pnpm build"
    },
    "dependencies": {
        "@geenius-ui/shared": "workspace:*",
        "clsx": "^2.1.1"
    },
    "devDependencies": {
        "solid-js": "^1.9.10",
        "typescript": "^5.7.0"
    },
    "peerDependencies": {
        "solid-js": "^1.9.0"
    }
}